@{
    ViewBag.Title = "Inicio de Sesión";
    Layout = "~/Views/Shared/_External_Layout.cshtml";
}

<div class="container">
    <div class="row bg-white rounded-4 shadow-lg overflow-hidden align-items-stretch mx-auto" style="min-height: 550px; max-width: 1000px;">

        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center text-center p-5 bg-light">
            <h1 class="text-primary fw-bold mb-2">¡Hola de nuevo!</h1>
            <p class="text-muted mb-5">Nos alegra verte por aquí. Ingresa para continuar.</p>
        </div>

        <div class="col-lg-6 d-flex flex-column justify-content-center p-5">
            <div class="w-100 mx-auto" style="max-width: 450px;">
                <h2 class="text-primary fw-bold mb-4">Bienvenido</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" action="">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control bg-light" id="Username" name="username" placeholder="Usuario" required autocomplete="off">
                        <label for="Username">Usuario</label>
                    </div>

                    <div class="form-floating mb-4">
                        <input type="password" class="form-control bg-light" id="Password" name="password" placeholder="Contraseña" required>
                        <label for="Password">Contraseña</label>
                    </div>

                    <div class="d-flex justify-content-end mb-4">
                        <a href="@Url.Action("RecoverPassword", "Home")" class="text-primary small text-decoration-none">¿Olvidaste tu contraseña?</a>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Iniciar Sesión</button>
                    </div>

                    <div class="text-center">
                        <small class="text-muted">¿No tienes una cuenta? <a href="@Url.Action("Register", "Home")" class="text-primary fw-bold text-decoration-none">Regístrate</a></small>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>