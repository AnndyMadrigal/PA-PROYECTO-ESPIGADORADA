@model PA_PROYECTO_ESPIGADORADA.Models.UserModel
@{
    ViewBag.Title = "Inicio de Sesión";
    Layout = "~/Views/Shared/_External_Layout.cshtml";
}

<div class="container my-5">
    <div class="row bg-white rounded-4 shadow-lg overflow-hidden align-items-stretch mx-auto" style="min-height: 550px; max-width: 1000px;">

        <div class="col-12 col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center text-center p-5 bg-light">
            <h1 class="text-primary fw-bold mb-2">¡Hola de nuevo!</h1>
            <p class="text-muted mb-5">Nos alegra verte por aquí. Ingresa para continuar.</p>
        </div>

        <div class="col-12 col-lg-6 d-flex flex-column justify-content-center p-5">
            <div class="w-100 mx-auto" style="max-width: 450px;">
                <h2 class="text-primary fw-bold mb-4">Bienvenido</h2>

                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @ViewBag.Mensaje
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @using (Html.BeginForm("Login", "Home", FormMethod.Post, new { @id = "FormLogin" }))
                {
                    <div class="form-floating mb-3">
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control bg-light", @placeholder = "Correo Electrónico", @type = "email", @required = "required", @autocomplete = "off" })
                        <label>Correo Electrónico</label>
                    </div>

                    <div class="form-floating mb-4">
                        @Html.TextBoxFor(m => m.Password, new { @class = "form-control bg-light", @type = "password", @placeholder = "Contraseña", @required = "required" })
                        <label>Contraseña</label>
                    </div>

                    <div class="d-flex justify-content-end mb-4">
                        <a href="@Url.Action("RecoverPassword", "Home")" class="text-primary small text-decoration-none">¿Olvidaste tu contraseña?</a>
                    </div>

                    <div class="d-grid mb-4">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Iniciar Sesión</button>
                    </div>

                    <div class="text-center">
                        <small class="text-muted">
                            ¿No tienes una cuenta?
                            <a href="@Url.Action("Register", "Home")" class="text-primary fw-bold text-decoration-none">Regístrate</a>
                        </small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts{

    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>
    <script src="~/Template/js/functions/login.js"></script>
}