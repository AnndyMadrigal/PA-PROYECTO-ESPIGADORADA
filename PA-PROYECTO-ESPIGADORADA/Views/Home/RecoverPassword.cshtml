
@{
    ViewBag.Title = "Recuperar Contraseña";
    Layout = "~/Views/Shared/_External_Layout.cshtml";
}


<div class="container">
    <div class="row bg-white rounded-4 shadow-lg overflow-hidden align-items-stretch mx-auto" style="min-height: 550px; max-width: 1000px;">

        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center text-center p-5 bg-light">
            <h1 class="text-primary fw-bold mb-2">Bienvenid@@</h1>
            <p class="text-muted mb-5">Te enviaremos un correo electrónico</p>
        </div>

        <div class="col-lg-6 d-flex flex-column justify-content-center p-5">
            <div class="w-100 mx-auto" style="max-width: 450px;">
                <h2 class="text-primary fw-bold mb-4">Recuperar el Acceso</h2>
                <p class="text-muted mb-4">Introduce tu correo electrónico para restablecer tu contraseña.</p>

                @if (ViewBag.Message != null)
                {<div class="alert alert-success">@ViewBag.Message</div>}
                @if (ViewBag.Error != null)
                {<div class="alert alert-danger">@ViewBag.Error</div>}

                <form method="post" action="">
                    <div class="form-floating mb-3">
                        <input type="text" class="form-control bg-light" id="Email" name="email" placeholder="Correo Electrónico" required autocomplete="off">
                        <label for="Email">Correo Electrónico</label>
                    </div>

                    <div class="d-grid mb-5">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Procesar</button>
                    </div>

                    <div class="text-center mt-5">
                        <small class="text-muted">¿Ya tienes una cuenta? <a href="@Url.Action("Login", "Home")" class="text-primary fw-bold text-decoration-none">Iniciar Sesión</a></small>
                    </div>
                </form>
            </div>
        </div>

    </div>
</div>
