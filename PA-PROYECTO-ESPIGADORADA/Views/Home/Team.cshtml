@{
    ViewBag.Title = "Nuestro Equipo";
}

<div class="container-fluid page-header py-6 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center pt-5 pb-3">
        <h1 class="display-4 text-white animated slideInDown mb-3">Nuestro Equipo</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a class="text-white" href="@Url.Action("Index", "Home")">Inicio</a></li>
                <li class="breadcrumb-item text-primary active" aria-current="page">Nuestro Equipo</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-xxl py-6">
    <div class="container">
        <div class="row g-5 align-items-center mb-5">
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.1s">
                <p class="text-primary text-uppercase mb-2">// Equipo Espiga Dorada</p>
                <h1 class="display-6 mb-4">Personas comprometidas con sabor, calidad y atención cercana.</h1>
                <p class="mb-4">
                    Nuestro equipo combina preparación, orden y creatividad para ofrecer productos frescos,
                    repostería bien presentada y una experiencia de compra confiable para cada cliente.
                </p>
                <div class="row g-3">
                    <div class="col-sm-6">
                        <div class="bg-light rounded p-4 h-100">
                            <div class="d-flex align-items-center mb-3">
                                <div class="flex-shrink-0 btn-square bg-primary rounded-circle me-3">
                                    <i class="fa fa-bread-slice text-white"></i>
                                </div>
                                <h5 class="mb-0">Panadería diaria</h5>
                            </div>
                            <span>Producción constante, control de calidad y productos frescos todos los días.</span>
                        </div>
                    </div>
                    <div class="col-sm-6">
                        <div class="bg-light rounded p-4 h-100">
                            <div class="d-flex align-items-center mb-3">
                                <div class="flex-shrink-0 btn-square bg-primary rounded-circle me-3">
                                    <i class="fa fa-birthday-cake text-white"></i>
                                </div>
                                <h5 class="mb-0">Repostería especial</h5>
                            </div>
                            <span>Decoración cuidada y apoyo en pedidos personalizados para fechas importantes.</span>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="row img-twice position-relative h-100">
                    <div class="col-6">
                        <img class="img-fluid rounded" src="~/Template/img/about-1.jpg" alt="Equipo Espiga Dorada" />
                    </div>
                    <div class="col-6 align-self-end">
                        <img class="img-fluid rounded" src="~/Template/img/about-2.jpg" alt="Trabajo en panadería" />
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 500px;">
            <p class="text-primary text-uppercase mb-2">// Integrantes</p>
            <h1 class="display-6 mb-4">Conoce a las personas que hacen posible cada pedido.</h1>
        </div>

        <div class="row g-4">
            <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.1s">
                <div class="team-item text-center rounded overflow-hidden h-100">
                    <img class="img-fluid w-100" src="~/Template/img/team-1.jpg" alt="Manuel Enrique Mora Monge" />
                    <div class="team-text">
                        <div class="team-title">
                            <h5>Mora Monge Manuel Enrique</h5>
                            <span>Maestro Panadero</span>
                        </div>
                        <div class="px-4 pb-4">
                            <small>Supervisa la producción diaria y el estándar de textura, cocción y frescura.</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.3s">
                <div class="team-item text-center rounded overflow-hidden h-100">
                    <img class="img-fluid w-100" src="~/Template/img/team-2.jpg" alt="Anndy Jossue Madrigal Delgado" />
                    <div class="team-text">
                        <div class="team-title">
                            <h5>Madrigal Delgado Anndy Jossue</h5>
                            <span>Especialista en Repostería</span>
                        </div>
                        <div class="px-4 pb-4">
                            <small>Trabaja en postres, acabados y presentaciones atractivas para vitrinas y encargos.</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.5s">
                <div class="team-item text-center rounded overflow-hidden h-100">
                    <img class="img-fluid w-100" src="~/Template/img/team-3.jpg" alt="Camila Alexandra Alfaro Rivera" />
                    <div class="team-text">
                        <div class="team-title">
                            <h5>Alfaro Rivera Camila Alexandra</h5>
                            <span>Encargada de Pedidos Especiales</span>
                        </div>
                        <div class="px-4 pb-4">
                            <small>Da seguimiento a solicitudes personalizadas y coordina detalles con cada cliente.</small>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3 col-md-6 wow fadeInUp" data-wow-delay="0.7s">
                <div class="team-item text-center rounded overflow-hidden h-100">
                    <img class="img-fluid w-100" src="~/Template/img/team-4.jpg" alt="Francinni de los Angeles Alfaro Salazar" />
                    <div class="team-text">
                        <div class="team-title">
                            <h5>Alfaro Salazar Francinni de los Angeles</h5>
                            <span>Coordinadora de Atención y Ventas</span>
                        </div>
                        <div class="px-4 pb-4">
                            <small>Apoya la atención al cliente, la toma de pedidos y la organización del servicio.</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-xxl bg-light my-6 py-6">
    <div class="container">
        <div class="row g-4 text-center">
            <div class="col-md-4 wow fadeInUp" data-wow-delay="0.1s">
                <div class="bg-white rounded p-4 h-100 shadow-sm">
                    <i class="fa fa-users fa-2x text-primary mb-3"></i>
                    <h5>Trabajo en equipo</h5>
                    <p class="mb-0">Cada pedido pasa por revisión de calidad, presentación y entrega.</p>
                </div>
            </div>
            <div class="col-md-4 wow fadeInUp" data-wow-delay="0.3s">
                <div class="bg-white rounded p-4 h-100 shadow-sm">
                    <i class="fa fa-star fa-2x text-primary mb-3"></i>
                    <h5>Compromiso con la calidad</h5>
                    <p class="mb-0">Buscamos sabor consistente y una experiencia agradable desde el primer contacto.</p>
                </div>
            </div>
            <div class="col-md-4 wow fadeInUp" data-wow-delay="0.5s">
                <div class="bg-white rounded p-4 h-100 shadow-sm">
                    <i class="fa fa-heart fa-2x text-primary mb-3"></i>
                    <h5>Atención cercana</h5>
                    <p class="mb-0">Nos enfocamos en escuchar al cliente y adaptar los pedidos cuando se necesita.</p>
                </div>
            </div>
        </div>
    </div>
</div>
