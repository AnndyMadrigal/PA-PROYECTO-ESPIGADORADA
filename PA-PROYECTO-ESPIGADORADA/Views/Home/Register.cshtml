@model PA_PROYECTO_ESPIGADORADA.Models.UserModel
@{
    ViewBag.Title = "Registro";
    Layout = "~/Views/Shared/_External_Layout.cshtml";
}

<div class="container my-5">
    <div class="row bg-white rounded-4 shadow-lg overflow-hidden align-items-stretch mx-auto" style="min-height: 550px; max-width: 1000px;">

        <div class="col-12 col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center text-center p-5 bg-light">
            <h1 class="text-primary fw-bold mb-2">¡Únete a Nosotros!</h1>
            <p class="text-muted mb-5">Crea tu cuenta y descubre todo lo que Espiga Dorada tiene para ofrecer.</p>
        </div>

        <div class="col-12 col-lg-6 d-flex flex-column justify-content-center p-4 p-md-5">
            <div class="w-100 mx-auto" style="max-width: 500px;">
                <h2 class="text-primary fw-bold mb-4">Registro</h2>

                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @ViewBag.Mensaje
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                @using (Html.BeginForm("Register", "Home", FormMethod.Post, new { @id = "FormRegister" }))
                {
                    <div class="form-floating mb-2">
                        @Html.TextBoxFor(m => m.Identification, new { @class = "form-control bg-light", @placeholder = "Identificación", @onkeyup = "CheckName()" })
                        <label for="Identification">Identificación</label>
                    </div>

                    <div class="form-floating mb-2">
                        @Html.TextBoxFor(m => m.Name, new { @class = "form-control bg-light SoloLectura", @placeholder = "Nombre", @readOnly = "true" })
                        <label for="Name">Nombre</label>
                    </div>

                    <div class="form-floating mb-2">
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control bg-light", @placeholder = "Correo Electrónico", @type = "email" })
                        <label for="Email">Correo Electrónico</label>
                    </div>

                    <div class="form-floating mb-4">
                        @Html.TextBoxFor(m => m.Password, new { @class = "form-control bg-light", @type = "password", @placeholder = "Contraseña" })
                        <label for="Password">Contraseña</label>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Registrarme</button>
                    </div>

                    <div class="text-center">
                        <small class="text-muted">
                            ¿Ya tienes una cuenta?
                            <a href="@Url.Action("Login", "Home")" class="text-primary fw-bold text-decoration-none">Inicia Sesión</a>
                        </small>
                    </div>
                }
            </div>
        </div>
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/jquery-validation@1.19.5/dist/jquery.validate.min.js"></script>

    <script src="~/Template/js/functions/register.js"></script>
}