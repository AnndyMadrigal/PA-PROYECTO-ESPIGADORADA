@{
    ViewBag.Title = "Registro";
    Layout = "~/Views/Shared/_External_Layout.cshtml";
}

<div class="container">
    <div class="row bg-white rounded-4 shadow-lg overflow-hidden align-items-stretch mx-auto" style="min-height: 550px; max-width: 1000px;">

        <div class="col-lg-6 d-none d-lg-flex flex-column justify-content-center align-items-center text-center p-5 bg-light">
            <h1 class="text-primary fw-bold mb-2">¡Únete a Nosotros!</h1>
            <p class="text-muted mb-5">Crea tu cuenta y descubre todo lo que Espiga Dorada tiene para ofrecer.</p>
        </div>

        <div class="col-lg-6 d-flex flex-column justify-content-center p-4 p-md-5">
            <div class="w-100 mx-auto" style="max-width: 500px;">
                <h2 class="text-primary fw-bold mb-4">Registro</h2>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger alert-dismissible fade show" role="alert">
                        @ViewBag.Error
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <form method="post" action="">
                    <div class="row g-2 mb-2">
                        <div class="col-md-6 form-floating">
                            <input type="text" class="form-control bg-light" id="FirstName" name="firstName" placeholder="Nombre" required>
                            <label for="FirstName" class="ms-2">Nombre</label>
                        </div>
                        <div class="col-md-6 form-floating">
                            <input type="text" class="form-control bg-light" id="LastName" name="lastName" placeholder="Apellidos" required>
                            <label for="LastName" class="ms-2">Apellidos</label>
                        </div>
                    </div>

                    <div class="form-floating mb-2">
                        <input type="email" class="form-control bg-light" id="Email" name="email" placeholder="Correo" required>
                        <label for="Email">Correo Electrónico</label>
                    </div>

                    <div class="form-floating mb-2">
                        <input type="text" class="form-control bg-light" id="Username" name="username" placeholder="Usuario" required>
                        <label for="Username">Usuario</label>
                    </div>

                    <div class="row g-2 mb-4">
                        <div class="col-md-6 form-floating">
                            <input type="password" class="form-control bg-light" id="Password" name="password" placeholder="Contraseña" required>
                            <label for="Password" class="ms-2">Contraseña</label>
                        </div>
                        <div class="col-md-6 form-floating">
                            <input type="password" class="form-control bg-light" id="ConfirmPassword" name="confirmPassword" placeholder="Confirmar" required>
                            <label for="ConfirmPassword" class="ms-2">Confirmar</label>
                        </div>
                    </div>

                    <div class="d-grid mb-3">
                        <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-bold">Registrarme</button>
                    </div>

                    <div class="text-center">
                        <small class="text-muted">¿Ya tienes una cuenta? <a href="@Url.Action("Login", "Home")" class="text-primary fw-bold text-decoration-none">Inicia Sesión</a></small>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
