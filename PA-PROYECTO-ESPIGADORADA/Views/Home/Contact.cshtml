@{
    ViewBag.Title = "Contacto";
}

<div class="container-fluid page-header py-6 wow fadeIn" data-wow-delay="0.1s">
    <div class="container text-center pt-5 pb-3">
        <h1 class="display-4 text-white animated slideInDown mb-3">Contacto</h1>
        <nav aria-label="breadcrumb animated slideInDown">
            <ol class="breadcrumb justify-content-center mb-0">
                <li class="breadcrumb-item"><a class="text-white" href="@Url.Action("Index", "Home")">Inicio</a></li>
                <li class="breadcrumb-item text-primary active" aria-current="page">Contacto</li>
            </ol>
        </nav>
    </div>
</div>

<div class="container-xxl py-6">
    <div class="container">
        <div class="row g-5">
            <div class="col-lg-5 wow fadeInUp" data-wow-delay="0.1s">
                <p class="text-primary text-uppercase mb-2">// Contáctanos</p>
                <h1 class="display-6 mb-4">Estamos listos para ayudarte con tus pedidos y consultas.</h1>
                <p class="mb-4">
                    Puedes comunicarte con nosotros para pedidos especiales, consultas sobre productos,
                    seguimiento de compras o información general sobre Espiga Dorada.
                </p>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0 btn-square bg-primary rounded-circle">
                        <i class="fa fa-map-marker-alt text-white"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-2">Dirección</h5>
                        <span>Puriscal, San José, Costa Rica</span>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0 btn-square bg-primary rounded-circle">
                        <i class="fa fa-phone-alt text-white"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-2">Teléfono</h5>
                        <span>+506 8899 1100</span>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0 btn-square bg-primary rounded-circle">
                        <i class="fa fa-envelope text-white"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-2">Correo electrónico</h5>
                        <span>espigadorada@gmail.com</span>
                    </div>
                </div>

                <div class="d-flex mb-4">
                    <div class="flex-shrink-0 btn-square bg-primary rounded-circle">
                        <i class="fa fa-clock text-white"></i>
                    </div>
                    <div class="ms-3">
                        <h5 class="mb-2">Horario de atención</h5>
                        <span>Lunes a sábado, 7:00 a.m. a 6:00 p.m.</span>
                    </div>
                </div>
            </div>

            <div class="col-lg-7 wow fadeInUp" data-wow-delay="0.5s">
                <div class="bg-light rounded p-4 p-sm-5 h-100 shadow-sm">
                    <h4 class="mb-4">Ubicación</h4>
                    <div class="ratio ratio-16x9 rounded overflow-hidden">
                        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d75879.58693430664!2d-84.18009203350381!3d10.008975944120527!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0fbdf08f2fa87%3A0xcaeae30dc4b41833!2sPanader%C3%ADa%20y%20Reposter%C3%ADa%20La%20Espiga%20Dorada!5e1!3m2!1ses-419!2scr!4v1776796884959!5m2!1ses-419!2scr" style="border:0;" allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>
                    </div>
                    <div class="row g-3 mt-4">
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100 bg-white">
                                <h6 class="text-primary mb-2">Pedidos especiales</h6>
                                <p class="mb-0">Escríbenos o llámanos para coordinar repostería personalizada y consultas de disponibilidad.</p>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="border rounded p-3 h-100 bg-white">
                                <h6 class="text-primary mb-2">Atención al cliente</h6>
                                <p class="mb-0">Te ayudamos con seguimiento de compras, cambios de pedido y orientación sobre nuestros productos.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
