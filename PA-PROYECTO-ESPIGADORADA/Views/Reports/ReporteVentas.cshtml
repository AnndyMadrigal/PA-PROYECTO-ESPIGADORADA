@using System.Linq
@model PA_PROYECTO_ESPIGADORADA.Models.ReporteVentasViewModel
@{
    ViewBag.Title = "Reporte de Ventas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-receipt me-2"></i>Reporte de Ventas</h4>
        <div>
            <a href="@Url.Action("ExportarPDF", "Reports", new {
                   tipo   = "ventas",
                   inicio = Model.Filtro.FechaInicio.HasValue ? Model.Filtro.FechaInicio.Value.ToString("yyyy-MM-dd") : "",
                   fin    = Model.Filtro.FechaFin.HasValue    ? Model.Filtro.FechaFin.Value.ToString("yyyy-MM-dd")    : "" })"
               class="btn btn-danger btn-sm me-2">
                <i class="bi bi-file-pdf me-1"></i>Exportar PDF
            </a>
            <a href="@Url.Action("ExportarExcel", "Reports", new {
                   tipo   = "ventas",
                   inicio = Model.Filtro.FechaInicio.HasValue ? Model.Filtro.FechaInicio.Value.ToString("yyyy-MM-dd") : "",
                   fin    = Model.Filtro.FechaFin.HasValue    ? Model.Filtro.FechaFin.Value.ToString("yyyy-MM-dd")    : "" })"
               class="btn btn-success btn-sm">
                <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <div class="text-muted small">Total ventas</div>
                <div class="fs-4 fw-bold text-primary">
                    @Model.CurrencySymbol@Model.TotalVentas.ToString("N2")
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <div class="text-muted small">Total impuesto</div>
                <div class="fs-4 fw-bold text-warning">
                    @Model.CurrencySymbol@Model.TotalImpuesto.ToString("N2")
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <div class="text-muted small">Total descuentos</div>
                <div class="fs-4 fw-bold text-danger">
                    @Model.CurrencySymbol@Model.TotalDescuento.ToString("N2")
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-sm mb-0" id="tblVentas">
                <thead class="table-dark">
                    <tr>
                        <th># Factura</th>
                        <th>Fecha</th>
                        <th>Cliente</th>
                        <th>Método pago</th>
                        <th class="text-end">Subtotal</th>
                        <th class="text-end">Descuento</th>
                        <th class="text-end">Impuesto</th>
                        <th class="text-end">Total</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Filas)
                    {
                        <tr>
                            <td>@r.NumeroFactura</td>
                            <td>@r.Fecha.ToString("dd/MM/yyyy")</td>
                            <td>@r.Cliente</td>
                            <td>@r.MetodoPago</td>
                            <td class="text-end">@Model.CurrencySymbol@r.Subtotal.ToString("N2")</td>
                            <td class="text-end">@Model.CurrencySymbol@r.Descuento.ToString("N2")</td>
                            <td class="text-end">@Model.CurrencySymbol@r.Impuesto.ToString("N2")</td>
                            <td class="text-end fw-bold">@Model.CurrencySymbol@r.Total.ToString("N2")</td>
                            <td>
                                <span class="badge @(r.Estado == "CONFIRMED" ? "bg-success" : "bg-warning text-dark")">
                                    @r.Estado
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <a href="@Url.Action("Index", "Reports")" class="btn btn-outline-secondary btn-sm mt-3">
        <i class="bi bi-arrow-left me-1"></i>Nuevo reporte
    </a>
</div>