@using System.Linq
@model PA_PROYECTO_ESPIGADORADA.Models.ReporteInventarioViewModel
@{
    ViewBag.Title = "Reporte de Inventario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container-fluid py-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4><i class="bi bi-box-seam me-2"></i>Reporte de Inventario</h4>
        <div>
            <a href="@Url.Action("ExportarPDF", "Reports", new {
                   tipo = "inventario",
                   categoriaId = Model.Filtro.CategoriaId })"
               class="btn btn-danger btn-sm me-2">
                <i class="bi bi-file-pdf me-1"></i>Exportar PDF
            </a>
            <a href="@Url.Action("ExportarExcel", "Reports", new {
                   tipo = "inventario",
                   categoriaId = Model.Filtro.CategoriaId })"
               class="btn btn-success btn-sm">
                <i class="bi bi-file-earmark-excel me-1"></i>Exportar Excel
            </a>
        </div>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <div class="text-muted small">Total productos</div>
                <div class="fs-4 fw-bold text-primary">
                    @Model.Filas.Count()
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <div class="text-muted small">Bajo stock</div>
                <div class="fs-4 fw-bold text-danger">
                    @Model.Filas.Count(x => x.BajoStock)
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card text-center py-3 shadow-sm">
                <div class="text-muted small">Valor total inventario</div>
                <div class="fs-4 fw-bold text-success">
                    @Model.CurrencySymbol@(Model.Filas.Sum(x => x.ValorTotal).ToString("N2"))
                </div>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-sm mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>SKU</th>
                        <th>Producto</th>
                        <th>Categoría</th>
                        <th class="text-end">Disponible</th>
                        <th class="text-end">Stock mín.</th>
                        <th class="text-end">Precio unit.</th>
                        <th class="text-end">Valor total</th>
                        <th>Estado</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var r in Model.Filas)
                    {
                        <tr class="@(r.BajoStock ? "table-danger" : "")">
                            <td>@r.SKU</td>
                            <td>@r.Nombre</td>
                            <td>@r.Categoria</td>
                            <td class="text-end">@r.Disponible.ToString("N2")</td>
                            <td class="text-end">@r.StockMinimo.ToString("N2")</td>
                            <td class="text-end">@Model.CurrencySymbol@r.PrecioUnidad.ToString("N2")</td>
                            <td class="text-end fw-bold">@Model.CurrencySymbol@r.ValorTotal.ToString("N2")</td>
                            <td>
                                @if (r.BajoStock)
                                {
                                    <span class="badge bg-danger">Bajo stock</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">OK</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <a href="@Url.Action("Index", "Reports")"
       class="btn btn-outline-secondary btn-sm mt-3">
        <i class="bi bi-arrow-left me-1"></i>Nuevo reporte
    </a>
</div>