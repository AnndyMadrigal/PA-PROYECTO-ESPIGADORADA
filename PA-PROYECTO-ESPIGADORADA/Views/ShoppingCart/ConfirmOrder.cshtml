@model PA_PROYECTO_ESPIGADORADA.Models.CheckoutViewModel
@{
    ViewBag.Title = "Confirmación del pedido";
}

<div class="container py-5 my-4">
    <div class="text-center mx-auto mb-5" style="max-width: 700px;">
        <h6 class="text-primary">Paso final</h6>
        <h1 class="display-6 mb-3">Confirmación del pedido</h1>
        <p class="text-muted mb-0">Revisa el detalle de tu compra, confirma tu pedido y selecciona el método de pago.</p>
    </div>

    @if (ViewBag.Mensaje != null)
    {
        <div class="alert alert-danger text-center mb-4">@ViewBag.Mensaje</div>
    }

    @if (Model != null && Model.Items != null && Model.Items.Any())
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="card border-0 shadow-sm rounded-4 mb-4">
                    <div class="card-header bg-white border-0 pt-4 px-4">
                        <h4 class="fw-bold text-primary mb-0">
                            <i class="fa fa-clipboard-check me-2"></i>Detalle del pedido
                        </h4>
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table align-middle table-hover mb-0">
                                <thead class="table-light text-secondary">
                                    <tr>
                                        <th class="py-3 px-4">Producto</th>
                                        <th class="py-3">Precio</th>
                                        <th class="py-3">Cantidad</th>
                                        <th class="py-3">Subtotal</th>
                                        <th class="py-3">IVA</th>
                                        <th class="py-3 text-end px-4">Total</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in Model.Items)
                                    {
                                        <tr class="border-bottom">
                                            <td class="px-4">
                                                <div class="d-flex align-items-center py-2">
                                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                                    {
                                                        <img src="@Url.Content(item.ImageUrl)" class="img-thumbnail rounded shadow-sm me-3" style="width: 60px; height: 60px; object-fit: cover;" />
                                                    }
                                                    else
                                                    {
                                                        <div class="bg-light rounded d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 60px; height: 60px;">
                                                            <i class="fa fa-box-open text-muted"></i>
                                                        </div>
                                                    }
                                                    <div>
                                                        <div class="fw-bold text-dark">@item.ProductName</div>
                                                        <small class="text-muted">Stock disponible: @item.AvailableStock.ToString("N0")</small>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="text-muted">₡@item.UnitPrice.ToString("N2")</td>
                                            <td class="text-muted">@item.Quantity</td>
                                            <td class="text-muted">₡@item.Subtotal.ToString("N2")</td>
                                            <td class="text-muted">₡@item.Tax.ToString("N2")</td>
                                            <td class="fw-bold text-primary text-end px-4">₡@item.Total.ToString("N2")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                @using (Html.BeginForm("PlaceOrder", "ShoppingCart", FormMethod.Post, new { @id = "checkoutForm" }))
                {
                    @Html.AntiForgeryToken()

                    <div class="card border-0 shadow-lg rounded-4 sticky-top" style="top: 100px;">
                        <div class="card-body p-4 p-md-5">
                            <h4 class="text-primary fw-bold mb-4">
                                <i class="fa fa-receipt me-2"></i>Resumen del pedido
                            </h4>

                            <div class="d-flex justify-content-between mb-3 text-muted">
                                <span>Subtotal</span>
                                <span>₡@Model.Subtotal.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3 text-muted">
                                <span>Descuento</span>
                                <span>₡@Model.DiscountTotal.ToString("N2")</span>
                            </div>
                            <div class="d-flex justify-content-between mb-3 text-muted">
                                <span>Impuestos</span>
                                <span>₡@Model.TaxTotal.ToString("N2")</span>
                            </div>

                            <hr class="my-4" />

                            <div class="d-flex justify-content-between mb-4">
                                <h5 class="fw-bold mb-0">Total</h5>
                                <h4 class="text-primary fw-bolder mb-0">₡@Model.Total.ToString("N2")</h4>
                            </div>

                            <div class="form-check bg-light rounded-4 p-3 mb-4">
                                @Html.CheckBoxFor(m => m.ConfirmPurchase, new { @class = "form-check-input", @id = "ConfirmPurchase" })
                                <label class="form-check-label fw-semibold ms-2" for="ConfirmPurchase">
                                    Confirmo que deseo realizar la compra
                                </label>
                                <div class="small text-muted mt-2">Al hacer check confirma que su pago será tramitado.</div>
                            </div>

                            <div id="paymentSection">
                                <div class="form-floating mb-3">
                                    @Html.DropDownListFor(m => m.PaymentMethod, Model.PaymentMethods, "Seleccione un método", new { @class = "form-select" })
                                    <label for="PaymentMethod">Método de pago</label>
                                    @Html.ValidationMessageFor(m => m.PaymentMethod, null, new { @class = "text-danger small" })
                                </div>

                                <div class="form-floating mb-3">
                                    @Html.TextBoxFor(m => m.PaymentReference, new { @class = "form-control", @placeholder = "Referencia de pago", @maxlength = "80" })
                                    <label for="PaymentReference">Referencia de pago</label>
                                    @Html.ValidationMessageFor(m => m.PaymentReference, null, new { @class = "text-danger small" })
                                </div>

                                <div class="form-floating mb-4">
                                    @Html.TextAreaFor(m => m.Notes, new { @class = "form-control", @placeholder = "Notas del método de pago", style = "height: 110px; resize:none;", @maxlength = "250" })
                                    <label for="Notes">Notas del método de pago</label>
                                    @Html.ValidationMessageFor(m => m.Notes, null, new { @class = "text-danger small" })
                                </div>
                            </div>

                            <button type="submit" id="btnPlaceOrder" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-sm" @(Model.ConfirmPurchase ? "" : "disabled")>
                                <i class="fa fa-check-circle me-2"></i>Realizar pedido
                            </button>

                            <a href="@Url.Action("Index", "ShoppingCart")" class="btn btn-outline-secondary w-100 rounded-pill mt-3">
                                <i class="fa fa-arrow-left me-2"></i>Volver al carrito
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5 my-5">
            <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px;">
                <i class="fa fa-shopping-basket fa-4x text-muted opacity-50"></i>
            </div>
            <h3 class="text-dark fw-bold">Tu carrito está vacío</h3>
            <p class="text-muted mb-4 fs-5">Agrega productos antes de confirmar el pedido.</p>
            <a href="@Url.Action("Catalog", "Products")" class="btn btn-primary btn-lg rounded-pill px-5 shadow-sm">
                <i class="fa fa-store me-2"></i>Explorar catálogo
            </a>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            function toggleConfirmPurchase() {
                var isChecked = $("#ConfirmPurchase").is(":checked");
                $("#btnPlaceOrder").prop("disabled", !isChecked);
            }

            $("#ConfirmPurchase").on("change", toggleConfirmPurchase);
            toggleConfirmPurchase();
        });
    </script>
}
