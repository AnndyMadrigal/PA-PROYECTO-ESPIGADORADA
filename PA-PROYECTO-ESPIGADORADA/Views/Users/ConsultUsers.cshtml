@model List<PA_PROYECTO_ESPIGADORADA.EntityFramework.users>

@{
    ViewBag.Title = "Gestión de Usuarios";
}

<div class="container vh-100 my-0">
    <div class="row">
        <div class="col-12 mt-5">
            <h2 class="text-primary fw-bold mb-4">Gestión de Usuarios</h2>

            <div class="mb-3">
                <a href="@Url.Action("Create")" class="btn btn-success"><i class="fa fa-plus me-2"></i>Crear Nuevo Usuario</a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <table id="usersTable" class="table table-striped table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th>Identificación</th>
                                <th>Nombre</th>
                                <th>Correo</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var user in Model)
                            {
                                <tr>
                                    <td>@user.identification</td>
                                    <td>@user.name</td>
                                    <td>@user.email</td>
                                    <td>
                                        <span class="badge @(user.is_active == 1 ? "bg-success" : "bg-danger")">
                                            @(user.is_active == 1 ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Edit", new { id = user.user_id })" class="btn btn-sm btn-primary" title="Editar">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                        <form action="@Url.Action("ToggleStatus", "Users")" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@user.user_id" />
                                            <button type="submit" class="btn btn-sm @(user.is_active == 1 ? "btn-danger" : "btn-success")"
                                                    title="@(user.is_active == 1 ? "Desactivar" : "Activar")">
                                                <i class="fa @(user.is_active == 1 ? "fa-ban" : "fa-check")"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- DataTables CSS/JS -->
    <script src="~/Template/js/functions/consultUser.js"></script>
}