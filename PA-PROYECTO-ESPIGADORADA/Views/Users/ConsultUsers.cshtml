@model List<PA_PROYECTO_ESPIGADORADA.EntityFramework.users>

@{
    ViewBag.Title = "Gestión de Usuarios";
}

<div class="container py-4 my-4">
    <div class="row">
        <div class="col-12 mt-4">
            <h2 class="text-primary fw-bold mb-4">Gestión de Usuarios</h2>

            <div class="mb-3">
                <a href="@Url.Action("Create")" class="btn btn-success"><i class="fa fa-plus me-2"></i>Crear Nuevo Usuario</a>
            </div>

            <div class="card shadow-sm border-0">
                <div class="card-body">
                    <div class="table-responsive">
                        <table id="usersTable" class="table table-hover table-borderless align-middle shadow-sm rounded overflow-hidden">
                            <thead class="table-primary text-secondary">
                                <tr>
                                <th class="py-3 px-4">Identificación</th>
                                <th class="py-3">Nombre</th>
                                <th class="py-3">Correo</th>
                                <th class="py-3">Estado</th>
                                <th class="py-3 px-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white">
                            @foreach (var user in Model)
                            {
                                <tr class="border-bottom">
                                    <td class="px-4 fw-bold text-muted">@user.identification</td>
                                    <td>@user.name</td>
                                    <td>@user.email</td>
                                    <td>
                                        <span class="badge @(user.is_active == 1 ? "bg-success" : "bg-danger")">
                                            @(user.is_active == 1 ? "Activo" : "Inactivo")
                                        </span>
                                    </td>
                                    <td class="px-4">
                                        <a href="@Url.Action("Edit", new { id = user.user_id })" class="btn btn-sm btn-outline-primary rounded-pill me-1" title="Editar">
                                            <i class="fa fa-edit"></i>
                                        </a>
                                        <form action="@Url.Action("ToggleStatus", "Users")" method="post" class="d-inline">
                                            <input type="hidden" name="id" value="@user.user_id" />
                                            <button type="submit" class="btn btn-sm @(user.is_active == 1 ? "btn-outline-danger" : "btn-outline-success") rounded-pill"
                                                    title="@(user.is_active == 1 ? "Desactivar" : "Activar")">
                                                <i class="fa @(user.is_active == 1 ? "fa-ban" : "fa-check")"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .dataTables_wrapper .row {
            margin-bottom: 0.5rem;
            align-items: center;
        }
        .dataTables_info {
            color: #6c757d;
            font-size: 0.9rem;
        }
        .page-link {
            border-radius: 5px !important;
            margin: 0 3px;
            border: none;
            color: #555;
        }
        .page-item.active .page-link {
            background-color: var(--bs-primary);
            color: #fff;
            box-shadow: 0 2px 5px rgba(0,0,0,0.15);
        }
        table.dataTable>thead>tr>th {
            border-bottom: 2px solid rgba(0,0,0,0.1) !important;
        }
        .dt-search input {
            border-radius: 20px;
            padding-left: 1rem;
            padding-right: 1rem;
        }
        .dt-length select {
            border-radius: 10px;
        }
    </style>
    <!-- DataTables CSS/JS -->
    <script src="~/Template/js/functions/consultUser.js"></script>
}