@using PA_PROYECTO_ESPIGADORADA.Models
@using System.Linq
@using System.Collections.Generic
@{
    var name = Session["Name"] ?? String.Empty;

    var cartItems = Session["Cart"] as List<ShoppingCartItem>;
    int cartCount = cartItems != null ? cartItems.Sum(i => i.Quantity) : 0;
}
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8">
    <title>Espiga Dorada</title>
    <meta content="width=device-width, initial-scale=1.0" name="viewport">
    <meta content="" name="keywords">
    <meta content="" name="description">

    <link rel="icon" href="@Url.Content("~/Template/img/spighe.png")" type="image/png">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&family=Playfair+Display:wght@600;700&display=swap" rel="stylesheet">

    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.10.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.4.1/font/bootstrap-icons.css" rel="stylesheet">

    <link href="~/Template/css/animate.min.css" rel="stylesheet" />
    <link href="~/Template/css/owl.carousel.min.css" rel="stylesheet" />
    <link href="~/Template/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/Template/css/style.css" rel="stylesheet" />

    <script src="https://code.jquery.com/jquery-3.4.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.0.0/dist/js/bootstrap.bundle.min.js"></script>
</head>

<body class="d-flex flex-column min-vh-100">

    <!-- Spinner Start -->
    <div id="spinner" class="show bg-white position-fixed translate-middle w-100 vh-100 top-50 start-50 d-flex align-items-center justify-content-center">
        <div class="spinner-grow text-primary" role="status"></div>
    </div>
    <!-- Spinner End -->
    <!-- Navbar Start -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark py-lg-0 px-lg-5 sticky-top">
        <a href="@Url.Action("Index", "Home")" class="navbar-brand ms-4 ms-lg-0">
            <h1 class="text-primary m-0"><i class="bi bi-flower1 me-2"></i>Espiga Dorada</h1>
        </a>
        <button type="button" class="navbar-toggler me-4" data-bs-toggle="collapse" data-bs-target="#navbarCollapse">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarCollapse">
            <div class="navbar-nav mx-auto p-4 p-lg-0">
                <a href="@Url.Action("Index", "Home")" class="nav-item nav-link">Inicio</a>
                @if (Session["Role_ID"] != null && ((int)Session["Role_ID"] == 1 || (int)Session["Role_ID"] == 2))
                {
                    <a class="nav-item nav-link" href="@Url.Action("Index", "Dashboard")">Dashboard</a>
                    <a class="nav-item nav-link" href="@Url.Action("ConsultUsers", "Users")">Gestión de Usuarios</a>
                    <a class="nav-item nav-link" href="@Url.Action("Index", "Products")">Gestión de Productos</a>
                    <a class="nav-item nav-link" href="@Url.Action("ConsultProviders", "Providers")">Gestión de Proveedores</a>
                    <a class="nav-item nav-link" href="@Url.Action("Index", "PurchaseOrders")">Órdenes de Compra</a>
                    <a class="nav-item nav-link" href="@Url.Action("Index", "Settings")">Configuración</a>
                    <!-- ✅ ENLACE NUEVO DE REPORTES -->
                    <a class="nav-item nav-link" href="@Url.Action("Index", "Reports")">
                        <i class="bi bi-bar-chart me-1"></i>Reportes
                    </a>
                }
                else
                {
                    <div class="nav-item dropdown">
                        <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Información</a>
                        <div class="dropdown-menu m-0">
                            <a href="@Url.Action("Team", "Home")" class="dropdown-item">Nuestro Equipo</a>
                            <a href="@Url.Action("Testimonial", "Home")" class="dropdown-item">Testimonios</a>
                        </div>
                    </div>
                    <a href="@Url.Action("Contact", "Home")" class="nav-item nav-link">Contacto</a>
                    <a class="nav-item nav-link" href="@Url.Action("Catalog", "Products")">Catálogo</a>
                }


            </div>
            <div class=" d-none d-lg-flex align-items-center">
                @if (Session["Role_ID"] != null && ((int)Session["Role_ID"] == 3))
                    {
                    <a href="@Url.Action("Index", "ShoppingCart")" class="d-flex align-items-center text-light text-decoration-none me-4 position-relative">
                        <i class="fa fa-shopping-cart fa-2x"></i>
                        <span id="cart-badge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger border border-2 border-dark" style="font-size: 0.70rem;">
                            @cartCount
                        </span>
                    </a>
                    }
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-light text-decoration-none dropdown-toggle" id="userDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="fa fa-user-circle fa-2x me-2"></i>
                            <span>@name</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                            <li><a class="dropdown-item" href="@Url.Action("Profile", "Account")"><i class="fa fa-user me-2"></i>Perfil</a></li>
                            <li><a class="dropdown-item" href="@Url.Action("ChangePassword", "Security")"><i class="fa fa-lock me-2"></i>Seguridad</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item" href="@Url.Action("Logout", "Home")"><i class="fa fa-sign-out-alt me-2"></i>Cerrar Sesión</a></li>
                        </ul>
                    </div>
                </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success text-center m-3">
            @TempData["Success"]
        </div>
    }

    <main class="flex-grow-1">
        @RenderBody()
    </main>

    <div class="container-fluid copyright text-light py-4 wow fadeIn" data-wow-delay="0.1s">
        <div class="container">
            <div class="row">
                <div class="col-md-6 text-center text-md-start mb-3 mb-md-0">
                    &copy; <a href="#">Espiga Dorada</a>, Todos los Derechos Reservados.
                </div>
                <div class="col-md-6 text-center text-md-end">
                    Designed By <a href="https://htmlcodex.com">HTML Codex</a>
                    <br>Distributed By: <a class="border-bottom" href="https://themewagon.com" target="_blank">ThemeWagon</a>
                </div>
            </div>
        </div>
    </div>

    <a href="#" class="btn btn-lg btn-primary btn-lg-square rounded-circle back-to-top"><i class="bi bi-arrow-up"></i></a>

    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.3.7/js/dataTables.bootstrap5.js"></script>
    <script src="~/Template/js/wow.min.js"></script>
    <script src="~/Template/js/easing.min.js"></script>
    <script src="~/Template/js/waypoints.min.js"></script>
    <script src="~/Template/js/counterup.min.js"></script>
    <script src="~/Template/js/owl.carousel.min.js"></script>
    <script src="~/Template/js/main.js"></script>

    <script>
        setTimeout(function () {
            $(".alert").fadeOut("slow");
        }, 3000);
    </script>

    <script src="~/Template/js/functions/activeView.js"></script>

    @RenderSection("Scripts", required: false)
</body>

</html>
