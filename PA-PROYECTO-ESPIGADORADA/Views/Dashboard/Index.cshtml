@model PA_PROYECTO_ESPIGADORADA.Models.DashboardModel

@{
    ViewBag.Title = "Dashboard";
}

<div class="container py-5">
    <div class="text-center mx-auto mb-5 wow fadeIn" data-wow-delay="0.1s" style="max-width: 700px;">
        <p class="text-primary text-uppercase mb-2 fw-bold tracking-wide"><i class="fa fa-chart-line me-2"></i> Panel de control</p>
        <h1 class="display-6 mb-3 text-dark fw-bolder">Resumen General del Sistema</h1>
    </div>

    <div class="row g-4">
        <!-- Ventas Hoy -->
        <div class="col-md-6 col-xl-3 wow fadeInUp" data-wow-delay="0.2s">
            <div class="card border-0 shadow-lg rounded-4 h-100 overflow-hidden transform-hover">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute top-0 end-0 mt-3 me-3 opacity-25">
                        <i class="fa fa-hand-holding-usd fa-4x text-success"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-start mb-4 position-relative z-1">
                        <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fa fa-dollar-sign fs-3"></i>
                        </div>
                        <span class="badge bg-success rounded-pill px-3 py-2 shadow-sm text-uppercase">Hoy</span>
                    </div>
                    <div class="position-relative z-1">
                        <h6 class="text-muted mb-2 text-uppercase fw-semibold" style="letter-spacing: 1px;">Ventas de hoy</h6>
                        <h2 class="fw-bolder text-dark mb-0">@Model.CurrencySymbol@Model.VentasHoy.ToString("N2")</h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stock Bajo -->
        <div class="col-md-6 col-xl-3 wow fadeInUp" data-wow-delay="0.3s">
            <div class="card border-0 shadow-lg rounded-4 h-100 overflow-hidden transform-hover bg-warning bg-opacity-10 border-bottom border-warning border-4">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute top-0 end-0 mt-3 me-3 opacity-25">
                        <i class="fa fa-exclamation-triangle fa-4x text-warning"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-start mb-4 position-relative z-1">
                        <div class="bg-warning text-dark rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fa fa-exclamation fs-3"></i>
                        </div>
                        <span class="badge bg-dark text-white rounded-pill px-3 py-2 shadow-sm text-uppercase"><i class="fa fa-bell text-warning me-1"></i> Atención</span>
                    </div>
                    <div class="position-relative z-1">
                        <h6 class="text-muted mb-2 text-uppercase fw-semibold" style="letter-spacing: 1px;">Stock bajo alerta</h6>
                        <h2 class="fw-bolder text-dark mb-0">@Model.ProductosStockBajo <span class="fs-5 fw-normal text-muted">productos</span></h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Facturas por pagar -->
        <div class="col-md-6 col-xl-3 wow fadeInUp" data-wow-delay="0.4s">
            <div class="card border-0 shadow-lg rounded-4 h-100 overflow-hidden transform-hover">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute top-0 end-0 mt-3 me-3 opacity-25">
                        <i class="fa fa-file-invoice-dollar fa-4x text-danger"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-start mb-4 position-relative z-1">
                        <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fa fa-receipt fs-3"></i>
                        </div>
                        <span class="badge bg-danger rounded-pill px-3 py-2 shadow-sm text-uppercase">Compras</span>
                    </div>
                    <div class="position-relative z-1">
                        <h6 class="text-muted mb-2 text-uppercase fw-semibold" style="letter-spacing: 1px;">Facturas por pagar</h6>
                        <h2 class="fw-bolder text-dark mb-0">@Model.FacturasPorPagar <span class="fs-5 fw-normal text-muted">pendientes</span></h2>
                    </div>
                </div>
            </div>
        </div>

        <!-- Total de productos -->
        <div class="col-md-6 col-xl-3 wow fadeInUp" data-wow-delay="0.5s">
            <div class="card border-0 shadow-lg rounded-4 h-100 overflow-hidden transform-hover bg-primary bg-opacity-10 border-bottom border-primary border-4">
                <div class="card-body p-4 position-relative">
                    <div class="position-absolute top-0 end-0 mt-3 me-3 opacity-25">
                        <i class="fa fa-boxes fa-4x text-primary"></i>
                    </div>
                    <div class="d-flex justify-content-between align-items-start mb-4 position-relative z-1">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 60px; height: 60px;">
                            <i class="fa fa-box-open fs-3"></i>
                        </div>
                        <span class="badge bg-dark rounded-pill px-3 py-2 shadow-sm text-uppercase text-white">Catálogo</span>
                    </div>
                    <div class="position-relative z-1">
                        <h6 class="text-muted mb-2 text-uppercase fw-semibold" style="letter-spacing: 1px;">Total en catálogo</h6>
                        <h2 class="fw-bolder text-dark mb-0">@Model.TotalProductos <span class="fs-5 fw-normal text-muted">registrados</span></h2>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección de resumen y acciones rápidas -->
    <div class="row g-4 mt-2">
        <div class="col-lg-8 wow fadeInUp" data-wow-delay="0.6s">
            <div class="card border-0 shadow-lg rounded-4 h-100">
                <div class="card-body p-4 p-md-5">
                    <div class="d-flex align-items-center mb-4 pb-3 border-bottom">
                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-3 shadow" style="width: 50px; height: 50px;">
                            <i class="fa fa-info-circle fs-4"></i>
                        </div>
                        <div>
                            <h4 class="fw-bolder text-dark mb-0">Resumen Operativo</h4>
                            <p class="text-muted mb-0">Detalles rápidos en tiempo real basados en la configuración de cada producto</p>
                        </div>
                    </div>

                    <div class="row g-4 text-center">
                        <div class="col-md-4 border-end-md">
                            <div class="p-3">
                                <i class="fa fa-cash-register fa-2x text-success mb-3"></i>
                                <h6 class="text-muted text-uppercase fw-bold">Rendimiento Hoy</h6>
                                <h3 class="fw-bolder text-dark mb-0">@Model.CurrencySymbol@Model.VentasHoy.ToString("N2")</h3>
                            </div>
                        </div>
                        <div class="col-md-4 border-end-md">
                            <div class="p-3">
                                <i class="fa fa-exclamation-circle fa-2x text-warning mb-3"></i>
                                <h6 class="text-muted text-uppercase fw-bold">Requieren Resurtirse</h6>
                                <h3 class="fw-bolder text-dark mb-0">@Model.ProductosStockBajo</h3>
                                <small class="text-muted px-2">Basado en stock mínimo individual.</small>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="p-3">
                                <i class="fa fa-file-invoice fa-2x text-danger mb-3"></i>
                                <h6 class="text-muted text-uppercase fw-bold">Por Pagar a Proveedores</h6>
                                <h3 class="fw-bolder text-dark mb-0">@Model.FacturasPorPagar</h3>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-4 wow fadeInUp" data-wow-delay="0.7s">
            <div class="card border-0 shadow-lg rounded-4 h-100">
                <div class="card-body p-4 d-flex flex-column">
                    <h4 class="fw-bold mb-4 border-bottom pb-2"><i class="fa fa-bolt me-2 text-warning"></i>Acciones rápidas</h4>

                    <div class="d-grid gap-3 flex-grow-1 align-content-center">
                        <a href="@Url.Action("Index", "Settings")" class="btn btn-outline-primary btn-lg rounded-pill shadow-sm">
                            <i class="fa fa-cogs me-2"></i>Ir a Configuración
                        </a>

                        <a href="@Url.Action("ConsultUsers", "Users")" class="btn btn-outline-dark btn-lg rounded-pill shadow-sm">
                            <i class="fa fa-users me-2"></i>Gestionar Usuarios
                        </a>
                        <a href="@Url.Action("Index", "Products")" class="btn btn-outline-dark btn-lg rounded-pill shadow-sm">
                            <i class="fa fa-users me-2"></i>Gestionar Productos
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <style>
        .tracking-wide {
            letter-spacing: 2px;
        }
        .transform-hover {
            transition: all 0.3s ease;
        }
        .transform-hover:hover {
            transform: translateY(-10px);
        }
        @Html.Raw("@media (min-width: 768px) { .border-end-md { border-right: 1px solid #dee2e6; } }")
    </style>
}