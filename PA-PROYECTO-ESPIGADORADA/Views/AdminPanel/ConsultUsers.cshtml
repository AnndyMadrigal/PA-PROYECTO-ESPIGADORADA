@model List<PA_PROYECTO_ESPIGADORADA.ViewModels.UserListViewModel>

@{
    ViewBag.Title = "Consulta de usuarios";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-4">
    <div class="card shadow-sm">
        <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Users</h4>
            <a href="@Url.Action("Create", "Users")" class="btn btn-light btn-sm">
                New User
            </a>
        </div>

        <div class="card-body">
            @if (TempData["Mensaje"] != null)
            {
                <div class="alert alert-danger">
                    @TempData["Mensaje"]
                </div>
            }

            <div class="table-responsive">
                <table class="table table-bordered table-hover">
                    <thead class="thead-light">
                        <tr>
                            <th>ID</th>
                            <th>Identification</th>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Status</th>
                            <th style="width: 200px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Count > 0)
                        {
                            foreach (var item in Model)
                            {
                                <tr>
                                    <td>@item.user_id</td>
                                    <td>@item.identification</td>
                                    <td>@item.name</td>
                                    <td>@item.email</td>
                                    <td>
                                        @if (item.is_active == 1)
                                        {
                                            <span class="badge badge-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        <a href="@Url.Action("Edit", "Users", new { id = item.user_id })"
                                           class="btn btn-warning btn-sm">
                                            Edit
                                        </a>

                                        @using (Html.BeginForm("Delete", "Users", FormMethod.Post, new { style = "display:inline;" }))
                                        {
                                            @Html.AntiForgeryToken()
                                            @Html.Hidden("id", item.user_id)

                                            <button type="submit"
                                                    class="btn btn-danger btn-sm"
                                                    onclick="return confirm('Are you sure you want to delete this user?');">
                                                Delete
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="6" class="text-center">No records found</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>