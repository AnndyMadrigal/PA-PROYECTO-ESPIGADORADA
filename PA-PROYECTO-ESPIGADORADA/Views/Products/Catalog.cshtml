@model List<PA_PROYECTO_ESPIGADORADA.Models.ProductViewModel>

@{
    ViewBag.Title = "Catálogo de Productos";
}

<div class="container py-5">
    <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
        <h6 class="text-primary">Nuestros Productos</h6>
        <h1 class="display-5 mb-4">Todo lo que necesitas, con el mejor sabor</h1>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="col-lg-3 col-md-4 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="card h-100 shadow-sm border-0 product-card">
                        <div class="position-relative overflow-hidden text-center" style="height: 250px; background-color: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(product.image_url))
                            {
                                <img src="@Url.Content(product.image_url)" alt="@product.product_name" class="img-fluid h-100 w-100" style="object-fit: cover;">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 w-100 text-muted">
                                    <i class="fa fa-image fa-4x"></i>
                                </div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column text-center p-4">
                            <h5 class="card-title fw-bold text-dark text-truncate" title="@product.product_name">@product.product_name</h5>
                            
                            <p class="text-muted smaller mb-2">SKU: @product.sku</p>
                            
                            <p class="card-text flex-grow-1" style="font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                @(string.IsNullOrEmpty(product.description) ? "Sin descripción" : product.description)
                            </p>

                            <!-- Precio desde la BD -->
                            <h4 class="text-primary mb-3 fw-bold">₡@product.unit_price.ToString("N2")</h4>

                            <button class="btn btn-outline-primary w-100 rounded-pill mt-auto" onclick="addToCart(@product.product_id)">
                                <i class="fa fa-shopping-cart me-2"></i>Añadir al carrito
                            </button>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="fa fa-box-open fa-3x mb-3"></i>
                <p>No hay productos disponibles en este momento.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function addToCart(productId) {
            // Lógica para añadir al carrito a implementar posteriormente
            alert("Producto " + productId + " añadido al carrito (Funcionalidad en desarrollo).");
        }
    </script>
    <style>
        .product-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        }
        .smaller {
            font-size: 0.8rem;
        }
    </style>
}
