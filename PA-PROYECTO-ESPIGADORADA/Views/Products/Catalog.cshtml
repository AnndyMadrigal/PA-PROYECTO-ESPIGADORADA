@model List<PA_PROYECTO_ESPIGADORADA.Models.ProductViewModel>

@{
    ViewBag.Title = "Catálogo de Productos";
}

<div class="container py-5">
    <div class="text-center mx-auto mb-5 wow fadeInUp" data-wow-delay="0.1s" style="max-width: 600px;">
        <h6 class="text-primary">Nuestros Productos</h6>
        <h1 class="display-5 mb-4">Todo lo que necesitas, con el mejor sabor</h1>
    </div>

    <div class="row g-4">
        @if (Model != null && Model.Any())
        {
            foreach (var product in Model)
            {
                <div class="col-lg-3 col-md-4 wow fadeInUp" data-wow-delay="0.1s">
                    <div class="card h-100 shadow-sm border-0 product-card">
                        <div class="position-relative overflow-hidden text-center" style="height: 250px; background-color: #f8f9fa;">
                            @if (!string.IsNullOrEmpty(product.image_url))
                            {
                                <img src="@Url.Content(product.image_url)" alt="@product.product_name" class="img-fluid h-100 w-100" style="object-fit: cover;">
                            }
                            else
                            {
                                <div class="d-flex align-items-center justify-content-center h-100 w-100 text-muted">
                                    <i class="fa fa-image fa-4x"></i>
                                </div>
                            }
                        </div>
                        <div class="card-body d-flex flex-column text-center p-4">
                            <h5 class="card-title fw-bold text-dark text-truncate" title="@product.product_name">@product.product_name</h5>
                            
                            <p class="text-muted smaller mb-2">SKU: @product.sku</p>
                            
                            <p class="card-text flex-grow-1" style="font-size: 0.9rem; overflow: hidden; text-overflow: ellipsis; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical;">
                                @(string.IsNullOrEmpty(product.description) ? "Sin descripción" : product.description)
                            </p>

                            <!-- Precio desde la BD -->
                            <h4 class="text-primary mb-3 fw-bold">₡@product.unit_price.ToString("N2")</h4>

                            <p class="text-success mb-3 fw-bold smaller">
                                <i class="fa fa-boxes me-1"></i> Disponible: @product.qty_available.ToString("0")
                            </p>

                            <div class="d-flex align-items-center justify-content-between mt-auto w-100">
                                <div class="input-group input-group-sm me-2" style="width: 110px;">
                                    <button class="btn btn-outline-secondary js-qty-minus" type="button"><i class="fa fa-minus"></i></button>
                                    <input type="number" class="form-control text-center px-1" id="qty_@product.product_id" value="1" min="1" max="@product.qty_available.ToString("0")" readonly />
                                    <button class="btn btn-outline-secondary js-qty-plus" type="button"><i class="fa fa-plus"></i></button>
                                </div>
                                <button class="btn btn-primary flex-grow-1 rounded-pill px-3 js-add-cart shadow-sm" 
                                        data-product-id="@product.product_id" 
                                        data-stock="@product.qty_available.ToString("0", System.Globalization.CultureInfo.InvariantCulture)">
                                    <i class="fa fa-shopping-cart"></i> Añadir
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12 text-center text-muted py-5">
                <i class="fa fa-box-open fa-3x mb-3 opacity-50"></i>
                <p class="fs-5">No hay productos disponibles en este momento.</p>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {

            // Lógica para botones de cantidad
            $(".js-qty-minus").click(function(){
                var input = $(this).siblings("input[type='number']");
                var val = parseInt(input.val());
                if(val > 1) input.val(val - 1);
            });

            $(".js-qty-plus").click(function(){
                var input = $(this).siblings("input[type='number']");
                var val = parseInt(input.val());
                var max = parseInt(input.attr("max"));
                if(val < max) input.val(val + 1);
            });

            // Lógica para añadir al carrito
            $(".js-add-cart").on("click", function () {
                var btn = $(this);
                var productId = btn.data("product-id");
                var availableStock = parseInt(btn.data("stock"));
                var qty = parseInt($("#qty_" + productId).val());

                if (availableStock <= 0 || qty > availableStock) {
                    alert("Stock insuficiente.");
                    return;
                }

                // Deshabilitar momentáneamente el botón para evitar doble clic
                var originalHtml = btn.html();
                btn.html('<i class="fa fa-spinner fa-spin"></i>');
                btn.prop('disabled', true);

                $.post('@Url.Action("AddToCart", "ShoppingCart")', { productId: productId, quantity: qty })
                    .done(function(res) {
                        btn.html(originalHtml);
                        btn.prop('disabled', false);

                        if(res.success) {
                            // Actualizar el numerito del carrito en el navbar
                            $('#cart-badge').text(res.totalItems)
                                            .addClass('animate__animated animate__rubberBand')
                                            .one('animationend', function() {
                                                $(this).removeClass('animate__animated animate__rubberBand');
                                            });

                            // Volver la cantidad al input a 1 por comodidad
                            $("#qty_" + productId).val(1);
                        } else {
                            alert(res.message);
                        }
                    })
                    .fail(function() {
                        btn.html(originalHtml);
                        btn.prop('disabled', false);
                        alert("Ocurrió un error al intentar agregar el producto al carrito.");
                    });
            });
        });
    </script>
    <style>
        .product-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
        }
        .smaller {
            font-size: 0.8rem;
        }
    </style>
}
