@model PA_PROYECTO_ESPIGADORADA.Models.OrderViewModel

@{
    ViewBag.Title = "Nueva Orden de Compra";
}

<div class="container mt-4">
    <h2 class="text-primary">Nueva Orden de Compra</h2>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    @using (Html.BeginForm())
    {
        <div class="mb-3">
            <label>Proveedor</label>
            @Html.DropDownListFor(m => m.supplier_id,
                ViewBag.Suppliers as SelectList,
                "Seleccione proveedor",
                new { @class = "form-control" })
        </div>

        <hr />

        <h4>Agregar Productos</h4>

        <div class="row">
            <div class="col-md-4">
                <label>Producto</label>
                @Html.DropDownList("product_id",
                    ViewBag.Products as SelectList,
                    "Seleccione",
                    new { @class = "form-control", id = "product_id" })
            </div>

            <div class="col-md-3">
                <label>Cantidad</label>
                <input type="number" id="quantity" class="form-control" />
            </div>

            <div class="col-md-3">
                <label>Costo</label>
                <input type="number" id="unit_cost" class="form-control" step="0.01" />
            </div>

            <div class="col-md-2 d-flex align-items-end">
                <button type="button" class="btn btn-primary w-100" onclick="addItem()">
                    Agregar
                </button>
            </div>
        </div>

        <br />

        <table class="table table-bordered" id="detailsTable">
            <thead class="table-dark">
                <tr>
                    <th>Producto</th>
                    <th>Cantidad</th>
                    <th>Costo</th>
                    <th>Total</th>
                    <th></th>
                </tr>
            </thead>
            <tbody></tbody>
        </table>

        <h4 class="text-end">Total: ₡<span id="totalGeneral">0</span></h4>

        <!-- IMPORTANTE -->
        <input type="hidden" id="details" name="details" />

        <button type="submit" class="btn btn-success">Guardar Orden</button>
    }
</div>

@section Scripts{
    <script>
        var details = [];

        function addItem() {

            var productId = document.getElementById("product_id").value;
            var productText = $("#product_id option:selected").text();
            var quantity = parseInt(document.getElementById("quantity").value);
            var cost = parseFloat(document.getElementById("unit_cost").value);

            if (!productId || !quantity || !cost) {
                alert("Complete todos los campos");
                return;
            }

            var total = quantity * cost;

            var item = {
                product_id: productId,
                quantity: quantity,
                unit_cost: cost
            };

            details.push(item);

            var row = "<tr>" +
                "<td>" + productText + "</td>" +
                "<td>" + quantity + "</td>" +
                "<td>" + cost.toFixed(2) + "</td>" +
                "<td>" + total.toFixed(2) + "</td>" +
                "<td><button type='button' class='btn btn-danger btn-sm' onclick='removeItem(this)'>X</button></td>" +
                "</tr>";

            $("#detailsTable tbody").append(row);

            updateTotal();
            updateJson();
        }

        function removeItem(btn) {
            var row = btn.parentNode.parentNode;
            var index = row.rowIndex - 1;

            details.splice(index, 1);
            row.remove();

            updateTotal();
            updateJson();
        }

        function updateTotal() {
            var total = 0;

            for (var i = 0; i < details.length; i++) {
                total += details[i].quantity * details[i].unit_cost;
            }

            document.getElementById("totalGeneral").innerText = total.toFixed(2);
        }

        function updateJson() {
            document.getElementById("details").value = JSON.stringify(details);
        }
    </script>
}



