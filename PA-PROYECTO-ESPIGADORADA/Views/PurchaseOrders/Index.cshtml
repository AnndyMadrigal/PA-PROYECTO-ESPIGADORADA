@model IEnumerable<dynamic>

@{
    ViewBag.Title = "Órdenes de Compra";
}

<div class="container mt-4">
    <h2 class="text-primary">Órdenes de Compra</h2>

    <a href="@Url.Action("Create","PurchaseOrders")" class="btn btn-success mb-3">
        Nueva Orden
    </a>

    <table class="table table-striped table-bordered" id="tablaOrdenes">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Proveedor</th>
                <th>Fecha</th>
                <th>Usuario</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.order_id</td>
                    <td>@item.supplier_name</td>
                    <td>@item.created_at</td>
                    <td>@item.created_by</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@section Scripts{
    <script>
        $(document).ready(function () {
            $('#tablaOrdenes').DataTable();
        });
    </script>
}



